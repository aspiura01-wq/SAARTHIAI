rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.size() >= 2 &&
               data.uid == request.auth.uid &&
               data.language in ['ENGLISH', 'HINDI', 'KANNADA'];
      }
      
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['language', 'biometricsEnabled']));
    }

    // Tasks
    match /tasks/{taskId} {
      function isValidTask(data) {
        return data.userId == request.auth.uid &&
               data.text is string && data.text.size() <= 500 &&
               data.completed is bool;
      }
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTask(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                      isValidTask(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Records
    match /records/{recordId} {
      function isValidRecord(data) {
        return data.userId == request.auth.uid &&
               data.name is string && data.name.size() <= 200 &&
               data.url is string && data.url.size() <= 1000;
      }
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidRecord(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                      isValidRecord(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Appointments
    match /appointments/{appointmentId} {
      function isValidAppointment(data) {
        return data.userId == request.auth.uid &&
               data.doctorName is string &&
               data.hospitalName is string;
      }
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAppointment(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                      isValidAppointment(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Budget
    match /budget/{budgetId} {
      function isValidBudget(data) {
        return data.userId == request.auth.uid &&
               data.amount is number &&
               data.type in ['income', 'expense'];
      }
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidBudget(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                      isValidBudget(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Reminders
    match /reminders/{reminderId} {
      function isValidReminder(data) {
        return data.userId == request.auth.uid &&
               data.medicineName is string && data.medicineName.size() <= 200 &&
               data.time is string &&
               data.enableMobile is bool &&
               data.enableWhatsapp is bool;
      }
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidReminder(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                      isValidReminder(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
